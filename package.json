{
  "name": "shieldcert",
  "version": "1.0.0",
  "description": "ShieldCert – Zero-Knowledge Certificate Verification on Midnight Network",
  "private": true,
  "scripts": {
    "compile": "compact compile contracts/shield_cert.compact --output managed",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "deploy:preview": "node --max-old-space-size=12288 node_modules/.bin/midnight-js-scripts deploy --network preview",
    "proof-server": "docker run -p 6300:6300 midnightnetwork/proof-server"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.20.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.11",
    "typescript": "^5.9.3"
  }
}
